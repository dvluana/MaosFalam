generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  email       String   @db.VarChar(255)
  gender      String   @default("female") @db.VarChar(10)
  sessionId   String   @map("session_id") @db.VarChar(64)
  clerkUserId String?  @map("clerk_user_id") @db.VarChar(100)
  emailOptIn  Boolean  @default(false) @map("email_opt_in")
  source      String   @default("organic") @db.VarChar(50)
  converted   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  readings    Reading[]
  userProfile UserProfile?

  @@index([email])
  @@index([sessionId])
  @@map("leads")
}

model UserProfile {
  clerkUserId          String   @id @map("clerk_user_id") @db.VarChar(100)
  leadId               String?  @unique @map("lead_id") @db.Uuid
  cpf                  String?  @db.VarChar(14)
  phone                String?  @db.VarChar(20)
  abacatepayCustomerId String?  @map("abacatepay_customer_id") @db.VarChar(100)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()

  lead        Lead?        @relation(fields: [leadId], references: [id])
  creditPacks CreditPack[]
  payments    Payment[]

  @@map("user_profiles")
}

model Reading {
  id           String   @id @default(uuid()) @db.Uuid
  leadId       String?  @map("lead_id") @db.Uuid
  clerkUserId  String?  @map("clerk_user_id") @db.VarChar(100)
  sessionId    String?  @map("session_id") @db.VarChar(64)
  targetName   String   @map("target_name") @db.VarChar(100)
  targetGender String   @default("female") @map("target_gender") @db.VarChar(10)
  isSelf       Boolean  @default(true) @map("is_self")
  attributes   Json
  report       Json
  tier         String   @default("free") @db.VarChar(10)
  confidence   Decimal? @db.Decimal(3, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  lead    Lead?    @relation(fields: [leadId], references: [id])
  payment Payment?

  @@index([clerkUserId])
  @@index([leadId])
  @@map("readings")
}

model CreditPack {
  id          String   @id @default(uuid()) @db.Uuid
  clerkUserId String   @map("clerk_user_id") @db.VarChar(100)
  paymentId   String?  @unique @map("payment_id") @db.Uuid
  packType    String   @map("pack_type") @db.VarChar(20)
  total       Int
  remaining   Int
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  userProfile UserProfile @relation(fields: [clerkUserId], references: [clerkUserId])
  payment     Payment?    @relation(fields: [paymentId], references: [id])

  @@index([clerkUserId])
  @@map("credit_packs")
}

model Payment {
  id                  String    @id @default(uuid()) @db.Uuid
  clerkUserId         String    @map("clerk_user_id") @db.VarChar(100)
  readingId           String?   @unique @map("reading_id") @db.Uuid
  abacatepayBillingId String?   @map("abacatepay_billing_id") @db.VarChar(100)
  packType            String    @map("pack_type") @db.VarChar(20)
  amountCents         Int       @map("amount_cents")
  method              String?   @db.VarChar(10)
  status              String    @default("pending") @db.VarChar(20)
  paidAt              DateTime? @map("paid_at") @db.Timestamptz()
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  userProfile UserProfile @relation(fields: [clerkUserId], references: [clerkUserId])
  reading     Reading?    @relation(fields: [readingId], references: [id])
  creditPack  CreditPack?

  @@index([abacatepayBillingId])
  @@map("payments")
}
