# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# IA (OpenAI)
OPENAI_API_KEY=

# Pagamento (AbacatePay)
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Banco (Neon)
# URL pooled — usado pelo Prisma client em runtime (via PgBouncer, hostname com "-pooler")
DATABASE_URL=postgresql://user:pass@ep-xxx.pooler.neon.tech/maosfalam?sslmode=require
# URL direta — usada APENAS pelo Prisma CLI (migrations). Hostname SEM "-pooler"
DIRECT_URL=postgresql://user:pass@ep-xxx.neon.tech/maosfalam?sslmode=require

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
LOG_LEVEL=debug
